   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Deepfake Detection Training Pipeline (Kaggle GPU Optimized)\n",
    "\n",
    "This notebook is engineered strictly for Kaggle Environments. It seamlessly hooks into the `xhlulu/140k-real-and-fake-faces` dataset (or similar FFHQ/StyleGAN splits) and trains an unbiased, robust ResNet50 classifier leveraging PyTorch and Kaggle's dual T4 GPU accelerators.\n",
    "\n",
    "## Quick Start (For Hackathons)\n",
    "1. Top Right: Turn on **Accelerator (GPU T4x2)**.\n",
    "2. Top Right: Turn on **Internet**.\n",
    "3. Right Column: Click **Add Data** -> Search for `140k real and fake faces` -> Add.\n",
    "4. Click **Run All**."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "source": [
    "!pip install -q torch torchvision opencv-python scikit-learn matplotlib"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "source": [
    "import os\n",
    "import time\n",
    "import copy\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "import torch\n",
    "import torch.nn as nn\n",
    "import torch.optim as optim\n",
    "from torch.utils.data import DataLoader, Dataset\n",
    "from torchvision import transforms, models\n",
    "from sklearn.metrics import accuracy_score, precision_score, recall_score, f1_score, confusion_matrix\n",
    "import cv2\n",
    "from PIL import Image\n",
    "\n",
    "print(f\"CUDA Available: {torch.cuda.is_available()}\")\n",
    "if torch.cuda.is_available():\n",
    "    print(f\"Device Name: {torch.cuda.get_device_name(0)}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### 1. Configuration & Data Mapping\n",
    "Update `KAGGLE_INPUT_DIR` based on the exact name of the dataset you add to your Kaggle environment."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "source": [
    "class Config:\n",
    "    # Common Kaggle Deepfake Dataset Paths\n",
    "    # Examples: '/kaggle/input/140k-real-and-fake-faces/real_vs_fake/real-vs-fake'\n",
    "    KAGGLE_INPUT_DIR = \"/kaggle/input/140k-real-and-fake-faces/real_vs_fake/real-vs-fake/train\"\n",
    "    REAL_SUBDIR = \"real\"\n",
    "    FAKE_SUBDIR = \"fake\"\n",
    "    \n",
    "    IMG_SIZE = 224\n",
    "    BATCH_SIZE = 64  # Increased for Kaggle T4 GPUs\n",
    "    EPOCHS = 15\n",
    "    LEARNING_RATE = 1e-4\n",
    "    NUM_WORKERS = 4  # Matches typical kaggle virtual cores\n",
    "    DEVICE = torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\n",
    "    MODEL_SAVE_PATH = \"deepfake_resnet50_kaggle.pth\"\n",
    "\n",
    "# Verify paths\n",
    "real_dir = os.path.join(Config.KAGGLE_INPUT_DIR, Config.REAL_SUBDIR)\n",
    "fake_dir = os.path.join(Config.KAGGLE_INPUT_DIR, Config.FAKE_SUBDIR)\n",
    "\n",
    "if os.path.exists(real_dir) and os.path.exists(fake_dir):\n",
    "    real_files = [os.path.join(real_dir, f) for f in os.listdir(real_dir)]\n",
    "    fake_files = [os.path.join(fake_dir, f) for f in os.listdir(fake_dir)]\n",
    "    print(f\"Found {len(real_files)} Real Images and {len(fake_files)} Fake Images.\")\n",
    "else:\n",
    "    print(\"WARNING: Dataset paths not found. Please attach a Kaggle Dataset to this notebook session.\")\n",
    "    # Fallback to empty for dry-run compilation checks\n",
    "    real_files, fake_files = [], []"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### 2. Dataset Custom Class & PyTorch Transforms\n",
    "Applies strong augmentation hooks (GaussianBlur, Jitter, Rotations) to absolutely shatter dataset biases."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "source": [
    "class KaggleDeepfakeDataset(Dataset):\n",
    "    def __init__(self, files: list, labels: list, transform=None):\n",
    "        self.files = files\n",
    "        self.labels = labels\n",
    "        self.transform = transform\n",
    "\n",
    "    def __len__(self):\n",
    "        return len(self.files)\n",
    "\n",
    "    def __getitem__(self, idx):\n",
    "        img_path = self.files[idx]\n",
    "        label = self.labels[idx]\n",
    "        \n",
    "        # Faster standard loading compared to heavy haarcascade processing\n",
    "        image = Image.open(img_path).convert('RGB')\n",
    "        \n",
    "        if self.transform:\n",
    "            image = self.transform(image)\n",
    "            \n",
    "        return image, torch.tensor(label, dtype=torch.long)\n",
    "\n",
    "train_transform = transforms.Compose([\n",
    "    transforms.Resize((Config.IMG_SIZE, Config.IMG_SIZE)),\n",
    "    transforms.RandomHorizontalFlip(p=0.5),\n",
    "    transforms.RandomRotation(degrees=15),\n",
    "    transforms.ColorJitter(brightness=0.2, contrast=0.2, saturation=0.2),\n",
    "    transforms.GaussianBlur(kernel_size=3, sigma=(0.1, 2.0)),\n",
    "    transforms.ToTensor(),\n",
    "    transforms.Normalize(mean=[0.485, 0.456, 0.406], std=[0.229, 0.224, 0.225])\n",
    "])\n",
    "\n",
    "val_transform = transforms.Compose([\n",
    "    transforms.Resize((Config.IMG_SIZE, Config.IMG_SIZE)),\n",
    "    transforms.ToTensor(),\n",
    "    transforms.Normalize(mean=[0.485, 0.456, 0.406], std=[0.229, 0.224, 0.225])\n",
    "])\n",
    "\n",
    "all_files = real_files + fake_files\n",
    "all_labels = [0] * len(real_files) + [1] * len(fake_files)\n",
    "\n",
    "from sklearn.model_selection import train_test_split\n",
    "if len(all_files) > 0:\n",
    "    X_train, X_val, y_train, y_val = train_test_split(all_files, all_labels, test_size=0.2, random_state=42, stratify=all_labels)\n",
    "    \n",
    "    train_dataset = KaggleDeepfakeDataset(X_train, y_train, transform=train_transform)\n",
    "    val_dataset = KaggleDeepfakeDataset(X_val, y_val, transform=val_transform)\n",
    "    \n",
    "    train_loader = DataLoader(train_dataset, batch_size=Config.BATCH_SIZE, shuffle=True, num_workers=Config.NUM_WORKERS)\n",
    "    val_loader = DataLoader(val_dataset, batch_size=Config.BATCH_SIZE, shuffle=False, num_workers=Config.NUM_WORKERS)\n",
    "   \n",
    "    # Bias Prevention: Calculating Class Weights for CrossEntropyLoss\n",
    "    num_real = len(real_files)\n",
    "    num_fake = len(fake_files)\n",
    "    total_samples = len(all_labels)\n",
    "    weight_real = total_samples / (2.0 * num_real) if num_real > 0 else 1.0\n",
    "    weight_fake = total_samples / (2.0 * num_fake) if num_fake > 0 else 1.0\n",
    "    class_weights = torch.tensor([weight_real, weight_fake], dtype=torch.float).to(Config.DEVICE)\n",
    "    print(f\"Computed Class Weights: Real={weight_real:.2f}, Fake={weight_fake:.2f}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### 3. Model Architecture (ResNet50 Backbone)\n",
    "Injects a rigid 512-neuron Head heavily saturated in Dropout to prevent plateau biases across 50% inference thresholds."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "source": [
    "def build_model(num_classes: int = 2) -> nn.Module:\n",
    "    # Using ResNet50\n",
    "    weights = models.ResNet50_Weights.DEFAULT\n",
    "    model = models.resnet50(weights=weights)\n",
    "    \n",
    "    # Freeze backbone initially for transfer learning phase\n",
    "    for param in model.parameters():\n",
    "        param.requires_grad = False\n",
    "        \n",
    "    num_ftrs = model.fc.in_features\n",
    "    model.fc = nn.Sequential(\n",
    "        nn.Linear(num_ftrs, 512),\n",
    "        nn.ReLU(),\n",
    "        nn.BatchNorm1d(512), # Added BatchNorm for Stability\n",
    "        nn.Dropout(0.5),\n",
    "        nn.Linear(512, num_classes)\n",
    "    )\n",
    "    \n",
    "    return model.to(Config.DEVICE)\n",
    "\n",
    "model = build_model()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### 4. Training Loop & Confusion Matrix Trackers\n",
    "Tracks F1 metrics explicitly, unfreezing backbones dynamically midway through the epoch sequence."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "source": [
    "def evaluate_model(model, dataloader, criterion):\n",
    "    model.eval()\n",
    "    running_loss = 0.0\n",
    "    all_preds = []\n",
    "    all_labels = []\n",
    "    \n",
    "    with torch.no_grad():\n",
    "        for inputs, labels in dataloader:\n",
    "            inputs, labels = inputs.to(Config.DEVICE), labels.to(Config.DEVICE)\n",
    "            outputs = model(inputs)\n",
    "            loss = criterion(outputs, labels)\n",
    "            running_loss += loss.item() * inputs.size(0)\n",
    "            \n",
    "            _, preds = torch.max(outputs, 1)\n",
    "            all_preds.extend(preds.cpu().numpy())\n",
    "            all_labels.extend(labels.cpu().numpy())\n",
    "            \n",
    "    epoch_loss = running_loss / len(dataloader.dataset)\n",
    "    acc = accuracy_score(all_labels, all_preds)\n",
    "    prec = precision_score(all_labels, all_preds, zero_division=0)\n",
    "    rec = recall_score(all_labels, all_preds, zero_division=0)\n",
    "    f1 = f1_score(all_labels, all_preds, zero_division=0)\n",
    "    cm = confusion_matrix(all_labels, all_preds)\n",
    "    \n",
    "    print(f\"Validation - Loss: {epoch_loss:.4f} | Acc: {acc:.4f} | P: {prec:.4f} | R: {rec:.4f} | F1: {f1:.4f}\")\n",
    "    print(f\"Confusion Matrix:\\n{cm}\")\n",
    "    return f1\n",
    "\n",
    "def train_loop():\n",
    "    if len(all_files) == 0:\n",
    "        print(\"No data loaded. Bypassing training loop.\")\n",
    "        return\n",
    "        \n",
    "    criterion = nn.CrossEntropyLoss(weight=class_weights)\n",
    "    optimizer = optim.Adam(model.parameters(), lr=Config.LEARNING_RATE)\n",
    "    scheduler = optim.lr_scheduler.ReduceLROnPlateau(optimizer, mode='max', factor=0.5, patience=2)\n",
    "    \n",
    "    best_f1 = 0.0\n",
    "    best_model_wts = copy.deepcopy(model.state_dict())\n",
    "\n",
    "    for epoch in range(Config.EPOCHS):\n",
    "        print(f\"\\nEpoch {epoch+1}/{Config.EPOCHS}\")\n",
    "        print(\"-\" * 20)\n",
    "        \n",
    "        if epoch == 4:\n",
    "            print(\"Unfreezing entire ResNet50 backbone for fine-tuning...\")\n",
    "            for param in model.parameters():\n",
    "                param.requires_grad = True\n",
    "                \n",
    "        model.train()\n",
    "        running_loss = 0.0\n",
    "        running_corrects = 0\n",
    "\n",
    "        for i, (inputs, labels) in enumerate(train_loader):\n",
    "            inputs, labels = inputs.to(Config.DEVICE), labels.to(Config.DEVICE)\n",
    "            \n",
    "            optimizer.zero_grad()\n",
    "            outputs = model(inputs)\n",
    "            _, preds = torch.max(outputs, 1)\n",
    "            loss = criterion(outputs, labels)\n",
    "            \n",
    "            loss.backward()\n",
    "            optimizer.step()\n",
    "            \n",
    "            running_loss += loss.item() * inputs.size(0)\n",
    "            running_corrects += torch.sum(preds == labels.data)\n",
    "            \n",
    "            if i % 100 == 0 and i > 0:\n",
    "                print(f\"Batch {i}/{len(train_loader)} - Temp Loss: {loss.item():.4f}\")\n",
    "\n",
    "        epoch_loss = running_loss / len(train_loader.dataset)\n",
    "        epoch_acc = running_corrects.double() / len(train_loader.dataset)\n",
    "        print(f\"Train - Loss: {epoch_loss:.4f} | Acc: {epoch_acc:.4f}\")\n",
    "        \n",
    "        epoch_f1 = evaluate_model(model, val_loader, criterion)\n",
    "        scheduler.step(epoch_f1)\n",
    "        \n",
    "        if epoch_f1 > best_f1:\n",
    "            best_f1 = epoch_f1\n",
    "            best_model_wts = copy.deepcopy(model.state_dict())\n",
    "            torch.save(model.state_dict(), Config.MODEL_SAVE_PATH)\n",
    "            print(f\">>> Best Model Saved to /kaggle/working/ -> {Config.MODEL_SAVE_PATH} (F1: {best_f1:.4f})\")\n",
    "\n",
    "train_loop()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### 5. FastAPI Inference Extraction Module\n",
    "How to run your `.pth` predictions robustly to ensure Temperature scaling pushes the logit probabilities confidently past 50%!"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "source": [
    "def kaggle_demo_inference(image_tensor, temperature=1.5):\n",
    "    \"\"\"\n",
    "    Simulates the exact predictor function you will paste into your local FastAPI app!\n",
    "    \"\"\"\n",
    "    model.eval()\n",
    "    with torch.no_grad():\n",
    "        inputs = image_tensor.unsqueeze(0).to(Config.DEVICE)\n",
    "        logits = model(inputs)\n",
    "        \n",
    "        # Temperature Calibration\n",
    "        scaled_logits = logits / temperature\n",
    "        probabilities = torch.softmax(scaled_logits, dim=1)\n",
    "        \n",
    "        confidence, predicted_class = torch.max(probabilities, 1)\n",
    "        result_label = \"Fake\" if predicted_class.item() == 1 else \"Real\"\n",
    "        \n",
    "        return {\n",
    "            \"result\": result_label,\n",
    "            \"confidence\": confidence.item(),\n",
    "            \"probabilities\": probabilities.cpu().numpy().tolist()\n",
    "        }\n",
    "\n",
    "# Dry Run inference test\n",
    "dummy_tensor = torch.randn(3, 224, 224)\n",
    "print(\"Dummy FastAPI API Response Hook Check:\")\n",
    "print(kaggle_demo_inference(dummy_tensor))"
   ]
  }
